# Copy this file to .env.cloud and fill in the values (.env.cloud is gitignored).
# Used by docker-compose.cloud.yml.

# RavenDB Cloud connection
RavenDb__Urls__0=https://<your-instance>.ravendb.cloud
RavenDb__Database=PdfSearch

# RavenDB client certificate: base64 of a PASSWORD-LESS .pfx, on a single line.
# The RAVENDB_CERT_BASE64 code path loads the PFX with password=null, so use the
# plain client certificate (NOT the *.with.password.pfx variant).
# Generate with:
#   base64 -w0 certificates/free.tromb.client.certificate.2026-05-13.pfx
RAVENDB_CERT_BASE64=

# Optional: pin the image tag (docker-compose.cloud.yml defaults to :latest)
# IMAGE_TAG=1.2.3

# Optional: forward logs to a reachable Seq instance (otherwise the Seq sink is a no-op)
# Serilog__WriteTo__1__Args__serverUrl=https://<your-seq-host>
